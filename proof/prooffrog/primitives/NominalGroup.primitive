Primitive NominalGroup(Int Nseed, Int NGelem, Set GroupElemSpace, Set ExponentSpace) {
    Int Nseed = Nseed;
    Int NGelem = NGelem;
    Set GroupElem = GroupElemSpace;
    Set Exponent = ExponentSpace;

    deterministic GroupElem Exp(GroupElem base, Exponent exp);
    deterministic GroupElem Generator();
    Exponent SampleExponent();
    deterministic Exponent DeriveExponent(BitString<Nseed> seed);
    deterministic injective BitString<NGelem> Encode(GroupElem elem);
}
