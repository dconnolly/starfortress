Primitive NominalGroup(Int Nseed, Int NGelem, Set GroupElemSpace, Set ExponentSpace) {
    Int Nseed = Nseed;
    Int NGelem = NGelem;
    Set GroupElem = GroupElemSpace;
    Set Exponent = ExponentSpace;

    GroupElem Exp(GroupElem base, Exponent exp);
    GroupElem Generator();
    Exponent SampleExponent();
    Exponent DeriveExponent(BitString<Nseed> seed);
    BitString<NGelem> Encode(GroupElem elem);
}
