Primitive UGKeyPair(Set PQKeySpace, Set TradKeySpace, Set CombinedKeySpace) {
    Set PQKey = PQKeySpace;
    Set TradKey = TradKeySpace;
    Set Combined = CombinedKeySpace;

    deterministic injective Combined Make(PQKey pq, TradKey trad);
    deterministic PQKey GetPQ(Combined k);
    deterministic TradKey GetTrad(Combined k);
}
