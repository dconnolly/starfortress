Primitive UGCiphertext(Set PQCiphertextSpace, Set TradCiphertextSpace, Set CombinedCiphertextSpace) {
    Set PQCiphertext = PQCiphertextSpace;
    Set TradCiphertext = TradCiphertextSpace;
    Set Combined = CombinedCiphertextSpace;

    deterministic injective Combined Make(PQCiphertext pq, TradCiphertext trad);
    deterministic PQCiphertext GetPQ(Combined ct);
    deterministic TradCiphertext GetTrad(Combined ct);
}
