// Proof that KEMCCA(UG) is IND-CCA secure assuming:
//   - PRG security (PRGSec(G))
//   - Component KEM IND-CCA security (KEMCCA(K))
//   - PRF security (PRFSec(H))
//
// Game hops (18 steps, 15 pass mechanically, 3 out-of-band):
//   KEMCCA(UG).Real
//  1  == GameCaseSplitReal                       (out-of-band: KEM correctness)
//  2  == PRGSec(G).Real compose R_PRG_Real       (embed PRG in keygen)
//  3  -> PRGSec(G).Random compose R_PRG_Real     (PRG security)
//  4  == KEMCCA(K).Real compose RB               (embed KEM challenge)
//  5  -> KEMCCA(K).Ideal compose RB              (KEM IND-CCA)
//  6  == PRFSec(H).Real compose RD               (embed PRF challenge)
//  7  -> PRFSec(H).Random compose RD             (PRF security)
//  8  == GameTableRandom                         (inline PRF Random table)
//  9  == GameFreshSS                             (out-of-band: table -> fresh)
// 10  == PRFSec(H).Random compose RE             (re-embed PRF)
// 11  -> PRFSec(H).Real compose RE               (PRF reverse)
// 12  == KEMCCA(K).Ideal compose RC              (embed KEM)
// 13  -> KEMCCA(K).Real compose RC               (KEM reverse)
// 14  == PRGSec(G).Random compose R_PRG_Ideal    (embed PRG)
// 15  -> PRGSec(G).Real compose R_PRG_Ideal      (PRG reverse)
// 16  == GameCaseSplitIdeal                      (re-embed keygen)
// 17  == KEMCCA(UG).Ideal                        (out-of-band: KEM correctness)
//
// Bound: Adv_KEMCCA(UG) <= 2*Adv_PRG + 2*Adv_KEMCCA(K) + 2*Adv_PRF

import 'primitives/KEM.primitive';
import 'primitives/NominalGroup.primitive';
import 'primitives/PRF.primitive';
import 'primitives/PRG.primitive';

import 'games/PRG-Security.game';
import 'games/PRF-Security.game';
import 'games/KEM-CCA.game';
import 'schemes/UG.scheme';

// ===================================================================
// R_PRG_Real: embed PRG challenge in keygen (Real side)
// ===================================================================
Reduction R_PRG_Real(KEM K, NominalGroup NG, PRF H, PRG G) compose PRGSec(G) against KEMCCA(UG(K, NG, H, G)).Adversary {
    K.EncapsKey ek_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.DecapsKey dk_PQ;
    K.SharedSecret ss_PQ;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        BitString<G.lambda + G.stretch> seed_full = challenger.Query();
        BitString<K.Nseed> kem_seed = seed_full[0 : K.Nseed];
        BitString<NG.Nseed> ng_seed = seed_full[K.Nseed : K.Nseed + NG.Nseed];
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        ss_PQ = encaps_result[0];
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss = H.evaluate(K.EncodeSharedSecret(ss_PQ),NG.Encode(k2) || K.EncodeCiphertext(ct_PQ) || NG.Encode(ct_T) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_ss_PQ = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// Reduction B: embed KEM challenge (paper's adversary B)
// ===================================================================
Reduction RB(NominalGroup NG, PRF H, KEM K, PRG G) compose KEMCCA(K) against KEMCCA(UG(K, NG, H, G)).Adversary {
    K.EncapsKey ek_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.Ciphertext kem_ct;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        ek_PQ = challenger.PK();
        kem_ct = challenger.CT();
        BitString<NG.Nseed> ng_seed <- BitString<NG.Nseed>;
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        K.SharedSecret k1 = challenger.SS();
        ss = H.evaluate(K.EncodeSharedSecret(k1),NG.Encode(k2) || K.EncodeCiphertext(kem_ct) || NG.Encode(ct_T) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        ek = [ek_PQ, ek_T];
        ct = [kem_ct, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == kem_ct) {
            K.SharedSecret k1 = challenger.SS();
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        K.SharedSecret? dec_k1 = challenger.DEC(c1);
        if (dec_k1 == None) {
            return None;
        }
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// Reduction D: embed PRF challenge (paper's adversary D)
// ===================================================================
Reduction RD(KEM K, NominalGroup NG, PRF H, PRG G) compose PRFSec(H) against KEMCCA(UG(K, NG, H, G)).Adversary {
    K.EncapsKey ek_PQ;
    K.DecapsKey dk_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        BitString<K.Nseed> kem_seed <- BitString<K.Nseed>;
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        BitString<NG.Nseed> ng_seed <- BitString<NG.Nseed>;
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss = challenger.Lookup(NG.Encode(k2) || K.EncodeCiphertext(ct_PQ) || NG.Encode(ct_T) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = challenger.Lookup(NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_k1 = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// GameTableRandom: explicit inlining of PRFSec(H).Random compose RD
// ===================================================================
Game GameTableRandom(KEM K, NominalGroup NG, PRF H, PRG G) {
    K.EncapsKey ek_PQ;
    K.DecapsKey dk_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    RandomFunctions<BitString<H.in>, BitString<H.out>> RF;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        RF <- RandomFunctions<BitString<H.in>, BitString<H.out>>;
        BitString<K.Nseed> kem_seed <- BitString<K.Nseed>;
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        BitString<NG.Nseed> ng_seed <- BitString<NG.Nseed>;
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss = RF(NG.Encode(k2) || K.EncodeCiphertext(ct_PQ) || NG.Encode(ct_T) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            return RF(NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_k1 = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// GameFreshSS: SS uses a fresh random sample instead of the table.
// ===================================================================
// GameTableRandom == GameFreshSS because the table entry for the SS key
// (k2 || ct1 || ct2 || ek_PQ || ek_T) is never queried in DEC:
// - DEC rejects c == challenge_ct (so c2 != ct2 when c1 == ct1)
// - When c1 == ct1 but c2 != ct2, dec_k2 = Exp(c2, dk_T) != k2 = Exp(ct2, dk_T)
//   so the DEC table key differs from the SS table key.
// The SS table entry is therefore only read once, making it equivalent
// to a fresh random sample. This is the single out-of-band step.
Game GameFreshSS(KEM K, NominalGroup NG, PRF H, PRG G) {
    K.EncapsKey ek_PQ;
    K.DecapsKey dk_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    RandomFunctions<BitString<H.in>, BitString<H.out>> RF;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        RF <- RandomFunctions<BitString<H.in>, BitString<H.out>>;
        BitString<K.Nseed> kem_seed <- BitString<K.Nseed>;
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        BitString<NG.Nseed> ng_seed <- BitString<NG.Nseed>;
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss <- BitString<H.out>;
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            return RF(NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_k1 = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// Reduction E: re-embed PRF for DEC (paper's adversary E)
// ===================================================================
Reduction RE(KEM K, NominalGroup NG, PRF H, PRG G) compose PRFSec(H) against KEMCCA(UG(K, NG, H, G)).Adversary {
    K.EncapsKey ek_PQ;
    K.DecapsKey dk_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        BitString<K.Nseed> kem_seed <- BitString<K.Nseed>;
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        BitString<NG.Nseed> ng_seed <- BitString<NG.Nseed>;
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss <- BitString<H.out>;
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = challenger.Lookup(NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_k1 = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// Reduction C: embed KEM challenge, reverse (paper's adversary C)
// ===================================================================
Reduction RC(NominalGroup NG, PRF H, KEM K, PRG G) compose KEMCCA(K) against KEMCCA(UG(K, NG, H, G)).Adversary {
    K.EncapsKey ek_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.Ciphertext kem_ct;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        ek_PQ = challenger.PK();
        kem_ct = challenger.CT();
        BitString<NG.Nseed> ng_seed <- BitString<NG.Nseed>;
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss <- BitString<H.out>;
        ek = [ek_PQ, ek_T];
        ct = [kem_ct, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == kem_ct) {
            K.SharedSecret k1 = challenger.SS();
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        K.SharedSecret? dec_k1 = challenger.DEC(c1);
        if (dec_k1 == None) {
            return None;
        }
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_k1),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// R_PRG_Ideal: embed PRG challenge in keygen (Ideal side)
// ===================================================================
Reduction R_PRG_Ideal(KEM K, NominalGroup NG, PRF H, PRG G) compose PRGSec(G) against KEMCCA(UG(K, NG, H, G)).Adversary {
    K.EncapsKey ek_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.DecapsKey dk_PQ;
    K.SharedSecret ss_PQ;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        BitString<G.lambda + G.stretch> seed_full = challenger.Query();
        BitString<K.Nseed> kem_seed = seed_full[0 : K.Nseed];
        BitString<NG.Nseed> ng_seed = seed_full[K.Nseed : K.Nseed + NG.Nseed];
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        ss_PQ = encaps_result[0];
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss <- BitString<H.out>;
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_ss_PQ = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// GameCaseSplitReal: bridge between KEMCCA(UG).Real and R_PRG_Real.
// ===================================================================
// Same as KEMCCA(UG).Real but with case-split DEC. The case split is
// equivalent to the simple DEC by KEM correctness:
//   K.Decaps(dk_PQ, ct_PQ) == ss_PQ for the challenge ciphertext.
// This is an out-of-band step.
Game GameCaseSplitReal(KEM K, NominalGroup NG, PRF H, PRG G) {
    K.EncapsKey ek_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.DecapsKey dk_PQ;
    K.SharedSecret ss_PQ;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        BitString<G.lambda> seed <- BitString<G.lambda>;
        BitString<G.lambda + G.stretch> seed_full = G.evaluate(seed);
        BitString<K.Nseed> kem_seed = seed_full[0 : K.Nseed];
        BitString<NG.Nseed> ng_seed = seed_full[K.Nseed : K.Nseed + NG.Nseed];
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        ss_PQ = encaps_result[0];
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss = H.evaluate(K.EncodeSharedSecret(ss_PQ),NG.Encode(k2) || K.EncodeCiphertext(ct_PQ) || NG.Encode(ct_T) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_ss_PQ = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// GameCaseSplitIdeal: bridge between R_PRG_Ideal and KEMCCA(UG).Ideal.
// ===================================================================
// Same as KEMCCA(UG).Ideal but with case-split DEC and explicit ss_PQ.
// The case split is equivalent to the simple DEC by KEM correctness.
// This is an out-of-band step.
Game GameCaseSplitIdeal(KEM K, NominalGroup NG, PRF H, PRG G) {
    K.EncapsKey ek_PQ;
    NG.GroupElem ek_T;
    NG.Exponent dk_T;
    K.DecapsKey dk_PQ;
    K.SharedSecret ss_PQ;
    K.Ciphertext kem_ct;
    K.Ciphertext ct_PQ;
    BitString<H.out> ss;
    [K.EncapsKey, NG.GroupElem] ek;
    [K.Ciphertext, NG.GroupElem] ct;

    Void Initialize() {
        BitString<G.lambda> seed <- BitString<G.lambda>;
        BitString<G.lambda + G.stretch> seed_full = G.evaluate(seed);
        BitString<K.Nseed> kem_seed = seed_full[0 : K.Nseed];
        BitString<NG.Nseed> ng_seed = seed_full[K.Nseed : K.Nseed + NG.Nseed];
        [K.EncapsKey, K.DecapsKey] kem_keypair = K.DeriveKeyPair(kem_seed);
        ek_PQ = kem_keypair[0];
        dk_PQ = kem_keypair[1];
        dk_T = NG.DeriveExponent(ng_seed);
        ek_T = NG.Exp(NG.Generator(), dk_T);
        [K.SharedSecret, K.Ciphertext] encaps_result = K.Encaps(ek_PQ);
        ss_PQ = encaps_result[0];
        kem_ct = encaps_result[1];
        ct_PQ = kem_ct;
        NG.Exponent ske = NG.SampleExponent();
        NG.GroupElem ct_T = NG.Exp(NG.Generator(), ske);
        NG.GroupElem k2 = NG.Exp(ek_T, ske);
        ss <- BitString<H.out>;
        ek = [ek_PQ, ek_T];
        ct = [ct_PQ, ct_T];
    }

    [K.EncapsKey, NG.GroupElem] PK() {
        return ek;
    }

    BitString<H.out> SS() {
        return ss;
    }

    [K.Ciphertext, NG.GroupElem] CT() {
        return ct;
    }

    BitString<H.out>? DEC([K.Ciphertext, NG.GroupElem] c) {
        K.Ciphertext c1 = c[0];
        NG.GroupElem c2 = c[1];
        if (c == ct) {
            return None;
        }
        if (c1 == ct_PQ) {
            NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
            BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
            return k;
        }
        if (c1 == kem_ct) {
            return None;
        }
        K.SharedSecret dec_ss_PQ = K.Decaps(dk_PQ, c1);
        NG.GroupElem dec_k2 = NG.Exp(c2, dk_T);
        BitString<H.out> k = H.evaluate(K.EncodeSharedSecret(dec_ss_PQ),NG.Encode(dec_k2) || K.EncodeCiphertext(c1) || NG.Encode(c2) || K.EncodeEncapsKey(ek_PQ) || NG.Encode(ek_T));
        return k;
    }
}

// ===================================================================
// Proof
// ===================================================================
proof:

let:
    Set KEMCiphertextSpace;
    Set EncapsKeySpace;
    Set DecapsKeySpace;
    Set GroupElemSpace;
    Set ExponentSpace;
    Int kem_nseed;
    Int ng_nseed;
    Int prf_lambda;
    Int prf_in;
    Int prf_out;

    Int kem_nct;
    Int kem_nek;
    Int ng_nelem;

    KEM K = KEM(kem_nseed, prf_lambda, kem_nct, kem_nek, BitString<prf_lambda>, KEMCiphertextSpace, EncapsKeySpace, DecapsKeySpace);
    NominalGroup NG = NominalGroup(ng_nseed, ng_nelem, GroupElemSpace, ExponentSpace);
    PRF H = PRF(prf_lambda, prf_in, prf_out);
    PRG G = PRG(kem_nseed, ng_nseed);
    UG UG_KEM = UG(K, NG, H, G);

assume:
    PRGSec(G);
    KEMCCA(K);
    PRFSec(H);

theorem:
    KEMCCA(UG_KEM);

games:
    // Step 1: out-of-band (KEM correctness: simple DEC -> case-split DEC)
    KEMCCA(UG_KEM).Real against KEMCCA(UG_KEM).Adversary;

    GameCaseSplitReal(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    // Embed PRG in keygen
    PRGSec(G).Real compose R_PRG_Real(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    PRGSec(G).Random compose R_PRG_Real(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    // === Theorem 2 core: KEM + PRF game hops (independent seeds) ===
    KEMCCA(K).Real compose RB(NG, H, K, G) against KEMCCA(UG_KEM).Adversary;

    KEMCCA(K).Ideal compose RB(NG, H, K, G) against KEMCCA(UG_KEM).Adversary;

    PRFSec(H).Real compose RD(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    PRFSec(H).Random compose RD(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    // Explicit inlining of PRF Random table
    GameTableRandom(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    // Step 10: out-of-band (single-use table entry -> fresh sample)
    GameFreshSS(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    PRFSec(H).Random compose RE(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    PRFSec(H).Real compose RE(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    KEMCCA(K).Ideal compose RC(NG, H, K, G) against KEMCCA(UG_KEM).Adversary;

    KEMCCA(K).Real compose RC(NG, H, K, G) against KEMCCA(UG_KEM).Adversary;

    PRGSec(G).Random compose R_PRG_Ideal(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    PRGSec(G).Real compose R_PRG_Ideal(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    // Step 17: out-of-band (KEM correctness: case-split DEC -> simple DEC)
    GameCaseSplitIdeal(K, NG, H, G) against KEMCCA(UG_KEM).Adversary;

    KEMCCA(UG_KEM).Ideal against KEMCCA(UG_KEM).Adversary;
